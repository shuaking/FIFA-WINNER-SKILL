{
  "$schema": "../../schema/agent-tool-catalog.schema.json",
  "schema_version": "agent.tool-catalog.v1",
  "catalog_id": "ai-octopus-paul-tool-catalog",
  "agent_id": "ai-octopus-paul-predictor",
  "description": "Machine-readable catalog for runtime agents that want to call AI Octopus Paul as a local CLI agent without embedding its internal Python modules.",
  "runtime": {
    "type": "local_cli",
    "working_directory": "repository_root",
    "transport": "stdio",
    "runtime_layer_status": "not_required_yet",
    "default_root_arg": "--root ."
  },
  "discovery_files": {
    "agent_card": "knowledge-base/agent/AGENT_CARD.json",
    "human_readme": "AGENT_README.md",
    "guardrails": "knowledge-base/agent/GUARDRAILS.md",
    "handoffs": "knowledge-base/agent/HANDOFFS.md",
    "trace_events": "knowledge-base/agent/TRACE_EVENTS.md"
  },
  "task_states": [
    "submitted",
    "working",
    "input_required",
    "blocked",
    "completed",
    "failed",
    "canceled"
  ],
  "tools": [
    {
      "id": "initialize_edition",
      "kind": "cli_tool",
      "description": "Create the edition-scoped match ledger, source registry, wiki index, and SQLite query index.",
      "command_template": "python scripts/worldcup_edition_init.py init --edition <edition> --root .",
      "inputs": ["edition", "root"],
      "outputs": [
        "knowledge-base/<edition>/data/match-ledger.json",
        "knowledge-base/<edition>/raw/source-registry.json",
        "knowledge-base/<edition>/wiki/index.md",
        "knowledge-base/<edition>/data/worldcup_<edition>.db"
      ],
      "idempotency": "safe_to_rerun_for_bootstrap; review generated placeholders before publishing",
      "safety_profile": "setup_only"
    },
    {
      "id": "audit_source_readiness",
      "kind": "cli_tool",
      "description": "Audit registered sources, tier metadata, allowed use, and blocker visibility.",
      "command_template": "python scripts/worldcup_source_readiness_auditor.py write --edition <edition> --root .",
      "inputs": ["edition", "root"],
      "outputs": ["knowledge-base/<edition>/data/source-readiness.json"],
      "reads": ["knowledge-base/<edition>/raw/source-registry.json"],
      "idempotency": "safe_to_rerun",
      "safety_profile": "evidence_boundary"
    },
    {
      "id": "plan_prediction_evidence",
      "kind": "cli_tool",
      "description": "Create the evidence checklist that controls confidence and visible missing-context warnings.",
      "command_template": "python scripts/worldcup_prediction_evidence_planner.py write --edition <edition> --root .",
      "inputs": ["edition", "root"],
      "outputs": [
        "knowledge-base/<edition>/data/prediction-evidence-plan.json",
        "knowledge-base/<edition>/wiki/synthesis/prediction-evidence-plan.md"
      ],
      "reads": [
        "knowledge-base/<edition>/data/match-ledger.json",
        "knowledge-base/<edition>/raw/source-registry.json",
        "knowledge-base/<edition>/data/rosters/fifa-squad-lists.json",
        "knowledge-base/<edition>/data/rankings/fifa-men-ranking.json"
      ],
      "idempotency": "safe_to_rerun",
      "safety_profile": "evidence_boundary"
    },
    {
      "id": "collect_daily_evidence",
      "kind": "cli_tool",
      "description": "Initialize or enrich the matchday evidence file with odds, news, injuries, referees, and manual notes.",
      "command_template": "python scripts/daily_evidence_input.py init --edition <edition> --date <YYYY-MM-DD> --root .",
      "alternate_commands": [
        "python scripts/worldcup_live_fetcher.py fetch-odds --edition <edition> --date <YYYY-MM-DD> --root .",
        "python scripts/worldcup_live_fetcher.py fetch-news --edition <edition> --date <YYYY-MM-DD> --root .",
        "python scripts/daily_evidence_input.py add-injury --edition <edition> --date <YYYY-MM-DD> --team-code <code> --player-name <name> --status <status> --root .",
        "python scripts/daily_evidence_input.py add-referee --edition <edition> --date <YYYY-MM-DD> --match-id <match_id> --name <name> --strictness <low|normal|high> --root .",
        "python scripts/daily_evidence_input.py add-odds --edition <edition> --date <YYYY-MM-DD> --match-id <match_id> --home-win <odds> --draw <odds> --away-win <odds> --root ."
      ],
      "inputs": ["edition", "date", "root"],
      "outputs": ["knowledge-base/<edition>/data/daily-evidence/<YYYY-MM-DD>.json"],
      "idempotency": "safe_to_rerun; manual evidence appends should be reviewed by caller",
      "safety_profile": "source_and_rate_limit_boundary"
    },
    {
      "id": "predict_daily",
      "kind": "cli_tool",
      "description": "Generate locked pre-match entertainment predictions for every not-started match on a date.",
      "command_template": "python scripts/daily_prediction_runner.py run --edition <edition> --date <YYYY-MM-DD> --root .",
      "inputs": ["edition", "date", "root", "now", "poster"],
      "outputs": [
        "knowledge-base/<edition>/data/reports/daily-predictions/<YYYY-MM-DD>.json",
        "knowledge-base/<edition>/wiki/reports/daily-predictions/<YYYY-MM-DD>.md"
      ],
      "reads": [
        "knowledge-base/<edition>/data/match-ledger.json",
        "knowledge-base/<edition>/data/daily-evidence/<YYYY-MM-DD>.json",
        "knowledge-base/<edition>/data/prediction-evidence-plan.json"
      ],
      "important_fields": [
        "predictions[].prediction",
        "predictions[].analysis_layers",
        "predictions[].scenario_analysis",
        "predictions[].decision_audit",
        "predictions[].play_card",
        "predictions[].disclaimer"
      ],
      "idempotency": "locks_existing_pre_match_reports",
      "safety_profile": "entertainment_prediction_only"
    },
    {
      "id": "predict_scoped",
      "kind": "cli_tool",
      "description": "Generate scoped predictions for one match, a team pair, a group, a phase, or all not-started matches.",
      "command_template": "python scripts/prediction_scoring_model.py predict --edition <edition> --match-id <match_id> --root .",
      "alternate_commands": [
        "python scripts/prediction_scoring_model.py predict --edition <edition> --teams \"Team A,Team B\" --root .",
        "python scripts/octopus_paul_agent.py predict --edition <edition> --group <group> --root .",
        "python scripts/octopus_paul_agent.py predict --edition <edition> --phase <phase> --root .",
        "python scripts/octopus_paul_agent.py predict --edition <edition> --all --root ."
      ],
      "inputs": ["edition", "match_id", "teams", "group", "phase", "root", "now"],
      "outputs": [
        "knowledge-base/<edition>/data/reports/custom-predictions/*.json",
        "knowledge-base/<edition>/wiki/reports/custom-predictions/*.md"
      ],
      "idempotency": "writes_scoped_report; caller should preserve locked pre-match reports",
      "safety_profile": "entertainment_prediction_only"
    },
    {
      "id": "build_report_prompt",
      "kind": "cli_tool",
      "description": "Build a Chinese long-form report prompt from a structured prediction report.",
      "command_template": "python scripts/prediction_report_prompt_builder.py build --edition <edition> --date <YYYY-MM-DD> --report-path <prediction-report.json> --match-id <match_id> --root .",
      "inputs": ["edition", "date", "report_path", "match_id", "root"],
      "outputs": [
        "knowledge-base/<edition>/data/reports/prompts/*.json",
        "knowledge-base/<edition>/wiki/reports/prompts/*.md"
      ],
      "idempotency": "safe_to_rerun",
      "safety_profile": "prompt_must_include_disclaimer"
    },
    {
      "id": "build_poster_prompt",
      "kind": "cli_tool",
      "description": "Build poster prompt material only when the user asks for poster or visual content.",
      "command_template": "python scripts/poster_prompt_builder.py build --edition <edition> --date <YYYY-MM-DD> --style showdown --match-id <match_id> --root .",
      "inputs": ["edition", "date", "report_path", "match_id", "style", "root"],
      "outputs": [
        "knowledge-base/<edition>/data/reports/posters/*.txt",
        "knowledge-base/<edition>/data/reports/posters/*.json"
      ],
      "idempotency": "safe_to_rerun",
      "safety_profile": "poster_prompt_only"
    },
    {
      "id": "generate_posters",
      "kind": "cli_tool",
      "description": "Generate poster images from a poster manifest when a configured image backend exists.",
      "command_template": "python scripts/poster_generator.py generate --manifest <poster-manifest.json> --backend <backend> --root .",
      "inputs": ["manifest", "backend", "root"],
      "outputs": [
        "knowledge-base/<edition>/data/reports/posters/*-poster-result.json",
        "assets/posters/*.png"
      ],
      "idempotency": "backend_dependent; blocked result is valid when backend is missing",
      "safety_profile": "do_not_fake_image_success"
    },
    {
      "id": "evaluate_predictions",
      "kind": "cli_tool",
      "description": "Evaluate locked predictions after final scores are recorded in the match ledger.",
      "command_template": "python scripts/prediction_evaluator.py write --edition <edition> --date <YYYY-MM-DD> --root .",
      "alternate_commands": [
        "python scripts/prediction_evaluation_dashboard.py write --edition <edition> --root ."
      ],
      "inputs": ["edition", "date", "root"],
      "outputs": [
        "knowledge-base/<edition>/data/reports/evaluations/<YYYY-MM-DD>.json",
        "knowledge-base/<edition>/data/reports/evaluations/aggregate-dashboard.json"
      ],
      "idempotency": "safe_to_rerun_after_final_scores",
      "safety_profile": "post_match_only"
    },
    {
      "id": "github_readiness",
      "kind": "cli_tool",
      "description": "Audit repo publication readiness, source guardrails, playability, and agent interoperability documents.",
      "command_template": "python scripts/worldcup_github_readiness_auditor.py write --edition <edition> --root .",
      "inputs": ["edition", "root", "now"],
      "outputs": ["knowledge-base/<edition>/data/github-readiness.json"],
      "idempotency": "safe_to_rerun",
      "safety_profile": "publication_audit"
    },
    {
      "id": "export_standalone",
      "kind": "cli_tool",
      "description": "Export a portable copy of the repo, schemas, agent docs, and selected edition knowledge base for another runtime agent.",
      "command_template": "python scripts/worldcup_export_standalone.py --edition <edition> --output <target_dir> --root .",
      "inputs": ["edition", "output", "root", "now"],
      "outputs": [
        "<target_dir>/AGENT_README.md",
        "<target_dir>/knowledge-base/agent/AGENT_CARD.json",
        "<target_dir>/knowledge-base/agent/TOOL_CATALOG.json",
        "<target_dir>/export-manifest.json"
      ],
      "idempotency": "overwrites_existing_output_subtree",
      "safety_profile": "portable_export"
    }
  ],
  "resources": [
    {
      "id": "agent_card",
      "kind": "json",
      "path": "knowledge-base/agent/AGENT_CARD.json",
      "description": "Machine-readable capability card and discovery entrypoint."
    },
    {
      "id": "tool_catalog",
      "kind": "json",
      "path": "knowledge-base/agent/TOOL_CATALOG.json",
      "description": "Tool, resource, prompt, guardrail, handoff, and trace-event index."
    },
    {
      "id": "match_ledger",
      "kind": "json",
      "path": "knowledge-base/<edition>/data/match-ledger.json",
      "description": "Canonical match schedule, teams, status, final scores, and report links."
    },
    {
      "id": "daily_evidence",
      "kind": "json",
      "path": "knowledge-base/<edition>/data/daily-evidence/<YYYY-MM-DD>.json",
      "description": "Canonical matchday evidence file for injuries, odds, news, referees, and manual notes."
    },
    {
      "id": "prediction_report",
      "kind": "json",
      "path": "knowledge-base/<edition>/data/reports/daily-predictions/<YYYY-MM-DD>.json",
      "description": "Locked pre-match prediction report with multi-layer analysis and safety disclaimer."
    },
    {
      "id": "sqlite_query_index",
      "kind": "sqlite",
      "path": "knowledge-base/<edition>/data/worldcup_<edition>.db",
      "description": "Query and indexing layer derived from JSON artifacts; JSON remains canonical."
    }
  ],
  "prompts": [
    {
      "id": "prediction_summary_response",
      "description": "Compact A2A response shape after prediction generation.",
      "source": "AGENT_README.md#Output Contract For A2A Callers",
      "inputs": ["status", "report", "matches", "main_pick", "confidence", "evidence_gaps", "key_layers", "safety"]
    },
    {
      "id": "longform_report_writer",
      "description": "Prompt artifact for writing a Chinese match report from structured JSON.",
      "source": "scripts/prediction_report_prompt_builder.py",
      "inputs": ["prediction_report", "match_id", "analysis_layers", "scenario_analysis", "decision_audit"]
    },
    {
      "id": "poster_prompt",
      "description": "Visual prompt artifact for poster creation when explicitly requested.",
      "source": "scripts/poster_prompt_builder.py",
      "inputs": ["prediction_report", "match_id", "style", "roster_context", "disclaimer"]
    }
  ],
  "guardrails": [
    {
      "id": "entertainment_only",
      "description": "Every prediction-like answer must include the entertainment-only disclaimer."
    },
    {
      "id": "no_betting_or_stake_advice",
      "description": "Never output stake size, bankroll advice, lottery advice, guaranteed win language, or betting calls."
    },
    {
      "id": "locked_pre_match_reports",
      "description": "Do not silently mutate a locked pre-match report after the match starts."
    },
    {
      "id": "evidence_gap_visibility",
      "description": "Surface blocked or partial evidence instead of upgrading confidence from thin data."
    }
  ],
  "handoffs": [
    {
      "id": "prediction_requested",
      "description": "Caller has a user request for a date, match, group, phase, teams, or all not-started matches."
    },
    {
      "id": "evidence_refresh_needed",
      "description": "Prediction can proceed only after source readiness, daily evidence, or match ledger setup is completed."
    },
    {
      "id": "poster_requested",
      "description": "Caller explicitly asks for poster prompt or image generation."
    },
    {
      "id": "evaluation_requested",
      "description": "Caller asks for post-match evaluation after final scores are available."
    }
  ],
  "trace_events": [
    {
      "id": "task.accepted",
      "description": "Runtime accepted a user or upstream-agent task."
    },
    {
      "id": "tool.started",
      "description": "Runtime started a CLI tool with sanitized arguments."
    },
    {
      "id": "tool.finished",
      "description": "Runtime finished a CLI tool with exit code, status, and artifact paths."
    },
    {
      "id": "artifact.written",
      "description": "A JSON, Markdown, SQLite, or media artifact was written."
    },
    {
      "id": "guardrail.triggered",
      "description": "A safety, source, or locked-report guardrail changed the response or blocked an action."
    },
    {
      "id": "prediction.locked",
      "description": "A pre-match report became the canonical locked artifact for a match or date."
    }
  ],
  "response_contract": {
    "status_values": [
      "created",
      "locked_existing_report",
      "blocked",
      "no_matches_found",
      "export_written",
      "ready",
      "ready_with_known_data_gaps"
    ],
    "required_prediction_response_fields": [
      "status",
      "report",
      "matches",
      "main_pick",
      "confidence",
      "evidence_gaps",
      "key_layers",
      "safety"
    ]
  }
}
